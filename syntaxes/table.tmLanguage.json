{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",

	"name": "Table",
	"scopeName": "source.table",

	"patterns": [
		{ "include": "#keywords" },
		{ "include": "#strings" }
	],

	"repository": {

		"keywords": {
			"patterns": [{
				"name": "keyword.control.table",
				"match": "\\b(if|while|for|return)\\b"
			}]
		},

		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.table",
					"begin": "\"",
					"end": "\"",
					"patterns": [{
						"name": "constant.character.escape.table",
						"match": "\\\\."
					}]
				},
				{
					"name": "string.quoted.single.table",
					"begin": "'",
					"end": "'",
					"patterns": [{
						"name": "constant.character.escape.table",
						"match": "\\\\."
					}]
				}
			]
		}
	}
}
